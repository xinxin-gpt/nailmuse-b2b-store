# Public site configuration
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.yourdomain.com

# Product import admin
# Use a long random value. Open /admin/import and enter the same value.
PRODUCT_IMPORT_ADMIN_TOKEN=replace-with-a-long-random-password

# Cloudflare R2: product JSON catalog + image upload
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nail-assets
R2_PRODUCTS_KEY=catalog/products.json

# Optional bulk image upload settings
R2_UPLOAD_DIR=public/products
R2_UPLOAD_PREFIX=products

# Inquiry email (optional). Without these, forms validate but do not send real mail.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=sales@yourdomain.com
INQUIRY_FROM_EMAIL=Website Inquiry <website@yourdomain.com>
